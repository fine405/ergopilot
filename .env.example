# Use a secret with at least 16 bytes outside local development.
ERGOPILOT_POLICY_KEY=replace-with-at-least-16-bytes
ERGOPILOT_STATION_BIN=target/debug/station-cli
ERGOPILOT_DATABASE_PATH=target/ergopilot-control-plane.sqlite
ERGOPILOT_PLANNER_ATTEMPTS_PATH=target/ergopilot-planner-attempts.json
ERGOPILOT_OPERATOR_ID=local-operator
ERGOPILOT_WEB_ORIGIN=http://localhost:3000
VITE_CONTROL_PLANE_URL=http://localhost:8787
ERGOPILOT_SIM_MOTION_STEP_MS=100

# Each key enables its matching planner provider.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
